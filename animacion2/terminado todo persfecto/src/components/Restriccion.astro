<div
    id="rest-contenedor"
    class="relative flex flex-col justify-center items-center p-8 bg-cover bg-center"
>
    <div id="rest-marco-wrap" class="relative">
        <img
            id="rest-marco"
            src="/imagenes/marco7.png"
            alt="Marco"
            class="h-auto w-[400px]"
        />

        <div
            id="rest-texto"
            class="absolute inset-0 flex items-center justify-center px-10 text-center"
        >
            <p
                class="font-crimson text-[#0a6c6e] text-base leading-relaxed font-bold"
            >
                CON CARIÑO, ESTE <br /> EVENTO ES SOLO PARA<br />ADULTOS.<br />
                AGRADECEMOS SU COMPRENSIÓN.
            </p>
        </div>
    </div>

    <img
        id="rest-lampara"
        src="/imagenes/lampara2.png"
        alt="Lámpara"
        class="absolute bottom-2 left-2 w-24 md:w-32"
    />
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initRestriccion() {
        const contenedor = document.getElementById("rest-contenedor");
        if (!contenedor) return;

        const marco = document.getElementById("rest-marco-wrap");
        const lampara = document.getElementById("rest-lampara");

        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: contenedor,
                start: "top 85%",
                toggleActions: "play none none reset",
            }
        });

        tl.from(marco, {
            scale: 0.9,
            opacity: 0,
            duration: 1.2,
            ease: "power2.out",
        })
        .from(lampara, {
            x: -40,
            y: 40,
            opacity: 0,
            duration: 1.2,
            ease: "power3.out",
        }, "-=0.8");
    }

    document.addEventListener("DOMContentLoaded", initRestriccion);
    document.addEventListener("astro:page-load", initRestriccion);
</script>

