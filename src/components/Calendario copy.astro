---
// Calendario.astro
---

<div
    class="relative w-full overflow-hidden flex items-center justify-center px-4 py-10"
>
    <div class="relative w-full max-w-[380px] flex flex-col items-center gap-3">
        <!-- MES -->
        <h2 class="font-great-vibes text-[42px] text-[#1a6b6a] m-0">Mayo</h2>

        <!-- SEPARADOR -->
        <img
            src="/imagenes/separador.png"
            alt=""
            class="w-[60%] h-auto pointer-events-none select-none"
        />

        <!-- DÍAS DE LA SEMANA -->
        <div class="grid grid-cols-7 w-full gap-y-1 mt-2">
            <span
                class="font-crimson text-[14px] font-bold text-[#1a6b6a] text-center uppercase"
                >D</span
            >
            <span
                class="font-crimson text-[14px] font-bold text-[#1a6b6a] text-center uppercase"
                >L</span
            >
            <span
                class="font-crimson text-[14px] font-bold text-[#1a6b6a] text-center uppercase"
                >M</span
            >
            <span
                class="font-crimson text-[14px] font-bold text-[#1a6b6a] text-center uppercase"
                >M</span
            >
            <span
                class="font-crimson text-[14px] font-bold text-[#1a6b6a] text-center uppercase"
                >J</span
            >
            <span
                class="font-crimson text-[14px] font-bold text-[#1a6b6a] text-center uppercase"
                >V</span
            >
            <span
                class="font-crimson text-[14px] font-bold text-[#1a6b6a] text-center uppercase"
                >S</span
            >
        </div>

        <!-- SEPARADOR LÍNEA -->
        <div class="w-full h-[1px] bg-[#c8960c]/40"></div>

        <!-- NÚMEROS DEL CALENDARIO - MAYO 2026 (empieza en Viernes) -->
        <div class="grid grid-cols-7 w-full gap-y-3 mt-1">
            <!-- Semana 1: vacíos hasta viernes -->
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >1</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >2</span
            >

            <!-- Semana 2 -->
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >3</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >4</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >5</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >6</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >7</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >8</span
            >
            <!-- 9 = FECHA DEL EVENTO con corazón -->
            <span class="relative flex items-center justify-center">
                <span
                    class="font-crimson text-[16px] text-[#c8960c] font-bold text-center"
                    >9</span
                >
                <span class="absolute -bottom-[10px] text-[#c8960c] text-[12px]"
                    >♥</span
                >
            </span>

            <!-- Semana 3 -->
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >10</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >11</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >12</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >13</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >14</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >15</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >16</span
            >

            <!-- Semana 4 -->
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >17</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >18</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >19</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >20</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >21</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >22</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >23</span
            >

            <!-- Semana 5 -->
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >24</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >25</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >26</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >27</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >28</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >29</span
            >
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >30</span
            >

            <!-- Semana 6 -->
            <span class="font-crimson text-[16px] text-[#1a6b6a] text-center"
                >31</span
            >
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
        </div>

        <!-- SEPARADOR INFERIOR -->
        <img
            src="/imagenes/separador.png"
            alt=""
            class="w-[60%] h-auto pointer-events-none select-none mt-2"
        />
    </div>
</div>
