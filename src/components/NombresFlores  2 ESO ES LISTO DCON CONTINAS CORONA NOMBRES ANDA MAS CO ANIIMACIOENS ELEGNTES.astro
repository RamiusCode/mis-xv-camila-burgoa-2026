---
// NombresFlores.astro
---

<div
    id="nombres-flores"
    class="relative w-full min-h-screen overflow-hidden flex flex-col items-center justify-start"
>
    <!-- CORTINA IZQUIERDA -->
    <img
        src="/imagenes/cortina.png"
        alt=""
        id="cortina-izq"
        class="absolute top-0 left-0 z-[5] pointer-events-none select-none w-[150px] h-auto"
    />

    <!-- CORTINA DERECHA espejada -->
    <img
        src="/imagenes/cortina.png"
        alt=""
        id="cortina-der"
        class="absolute top-0 right-0 z-[5] pointer-events-none select-none w-[150px] h-auto scale-x-[-1]"
    />

    <!-- CONTENIDO CENTRAL -->
    <div
        class="relative z-[10] flex flex-col items-center justify-center text-center px-6 gap-3 mt-[100px]"
    >
        <!-- CORONA → cambia w-[120px] para el tamaño -->
        <img
            src="/imagenes/corona.png"
            alt="Corona"
            id="corona"
            class="pointer-events-none block w-[120px] h-auto"
        />

        <!-- MIS XV AÑOS → cambia text-[24px] para tamaño, mt-[12px] para separación -->
        <p
            id="texto-mis-xv"
            class="m-0 font-crimson font-bold uppercase text-[#c8960c] text-[24px] tracking-[0.28em] mt-[12px]"
        >
            MIS XV AÑOS
        </p>

        <!-- NOMBRE → cambia text-[52px] para tamaño -->
        <h1
            id="texto-nombre"
            class="m-0 font-great-vibes pt-10 font-normal text-[#c8960c] whitespace-nowrap text-[52px] leading-[1.1]"
        >
            Camila Burgos
        </h1>
    </div>
</div>

<!-- BOTÓN FLOTANTE PLAY/PAUSE -->
<button
    id="btn-audio-control"
    aria-label="Controlar música"
    class="fixed bottom-6 right-6 z-[9999] w-12 h-12 rounded-full shadow-lg
           bg-white border border-[#c8960c]/30 flex items-center justify-center
           transition-all duration-300 hover:scale-110 active:scale-95"
    style="opacity: 0; pointer-events: none;"
>
    <svg
        id="icono-pause"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-[#c8960c]"
        viewBox="0 0 24 24"
        fill="currentColor"
    >
        <rect x="6" y="4" width="4" height="16" rx="1"></rect>
        <rect x="14" y="4" width="4" height="16" rx="1"></rect>
    </svg>
    <svg
        id="icono-play"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-[#c8960c] hidden"
        viewBox="0 0 24 24"
        fill="currentColor"
    >
        <path d="M8 5v14l11-7z"></path>
    </svg>
</button>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        gsap.from("#cortina-izq", {
            x: -80,
            opacity: 0,
            duration: 2.2,
            ease: "sine.out",
            delay: 0.3,
        });
        gsap.from("#cortina-der", {
            x: 80,
            opacity: 0,
            duration: 2.2,
            ease: "sine.out",
            delay: 0.3,
        });
        gsap.from("#corona", {
            y: -30,
            opacity: 0,
            duration: 1.4,
            ease: "elastic.out(1,0.6)",
            delay: 0.5,
        });
        gsap.from("#texto-mis-xv", {
            y: 18,
            opacity: 0,
            duration: 0.9,
            ease: "power2.out",
            delay: 1.0,
        });
        const h1 = document.querySelector<HTMLElement>("#texto-nombre");
        if (h1) {
            const texto = h1.textContent ?? "";
            h1.innerHTML = texto.split("").map(c =>
                c === " "
                    ? `<span style="display:inline-block">&nbsp;</span>`
                    : `<span style="display:inline-block">${c}</span>`
            ).join("");

            gsap.from(h1.querySelectorAll("span"), {
                opacity: 0,
                y: 3,
                duration: 0.5,
                stagger: 0.09,
                ease: "sine.out",
                delay: 1.2,
            });
        }

        const btnAudio = document.getElementById(
            "btn-audio-control",
        ) as HTMLButtonElement;
        const iconoPlay = document.getElementById("icono-play");
        const iconoPause = document.getElementById("icono-pause");

        const intervalo = setInterval(() => {
            const audio = (window as any).audioGlobal;
            if (audio) {
                clearInterval(intervalo);
                gsap.to(btnAudio, {
                    opacity: 1,
                    duration: 0.5,
                    ease: "power2.out",
                    onStart: () => {
                        btnAudio.style.pointerEvents = "auto";
                    },
                });
                iconoPlay?.classList.add("hidden");
                iconoPause?.classList.remove("hidden");

                btnAudio.addEventListener("click", () => {
                    const audioActual = (window as any).audioGlobal;
                    const reproduciendo = (window as any)
                        .estaReproduciendoGlobal;
                    if (!audioActual) return;
                    if (reproduciendo) {
                        audioActual.pause();
                        (window as any).estaReproduciendoGlobal = false;
                        iconoPause?.classList.add("hidden");
                        iconoPlay?.classList.remove("hidden");
                    } else {
                        audioActual.play();
                        (window as any).estaReproduciendoGlobal = true;
                        iconoPlay?.classList.add("hidden");
                        iconoPause?.classList.remove("hidden");
                    }
                    gsap.fromTo(
                        btnAudio,
                        { scale: 0.85 },
                        { scale: 1, duration: 0.3, ease: "back.out(2)" },
                    );
                });
            }
        }, 300);
    });
</script>
