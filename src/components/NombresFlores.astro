---
// NombresFlores.astro
---

<div
    id="nombres-flores"
    class="relative w-full overflow-hidden flex flex-col items-center justify-start pb-[30px]"
>
    <!-- CORTINA IZQUIERDA -->
    <img
        src="/imagenes/cortina.png"
        alt=""
        id="cortina-izq"
        class="absolute top-0 left-0 z-[5] pointer-events-none select-none w-[150px] h-auto"
    />

    <!-- CORTINA DERECHA espejada -->
    <img
        src="/imagenes/cortina.png"
        alt=""
        id="cortina-der"
        class="absolute top-0 right-0 z-[5] pointer-events-none select-none w-[150px] h-auto scale-x-[-1]"
    />

    <!-- CONTENIDO CENTRAL -->
    <div
        class="relative z-[10] flex flex-col items-center justify-center text-center px-6 gap-3 mt-[100px]"
    >
        <!-- CORONA -->
        <img
            src="/imagenes/corona.png"
            alt="Corona"
            id="corona"
            class="pointer-events-none block w-[120px] h-auto"
        />

        <!-- MIS XV AÑOS -->
        <p
            id="texto-mis-xv"
            class="m-0 font-crimson font-bold uppercase text-[#c8960c] text-[24px] tracking-[0.28em] mt-[12px]"
        >
            MIS XV AÑOS
        </p>

        <!-- NOMBRE -->
        <h1
            id="texto-nombre"
            class="m-0 font-great-vibes pt-10 font-normal text-[#c8960c] whitespace-nowrap text-[52px] leading-[1.1]"
        >
            Camila Burgoa
        </h1>
    </div>

    <!-- COJÍN CON LÁMPARA (abajo izquierda) -->
    <!-- <img
        src="/imagenes/cogin.png"
        alt="Cojín con lámpara"
        id="cogin"
        class="absolute bottom-[8%] left-[5%] z-[6] pointer-events-none select-none w-[140px] h-auto"
    /> -->

    <!-- PERSONAJE (abajo derecha) -->
    <!-- <img
        src="/imagenes/personaje.png"
        alt="Personaje"
        id="personaje"
        class="absolute bottom-0 right-[2%] z-[6] pointer-events-none select-none w-[90px] h-auto"
    /> -->

    <!-- SEPARADOR → cambia w-[300px] para el ancho -->
    <img
        id="separador-flores"
        src="/imagenes/separador.png"
        alt=""
        class="pointer-events-none select-none w-[250px] h-auto mt-[40px] mx-auto block"
    />
</div>

<!-- BOTÓN FLOTANTE PLAY/PAUSE -->
<button
    id="btn-audio-control"
    aria-label="Controlar música"
    class="fixed bottom-6 right-6 z-[9999] w-12 h-12 rounded-full shadow-lg
           bg-white border border-[#c8960c]/30 flex items-center justify-center
           transition-all duration-300 hover:scale-110 active:scale-95"
    style="opacity: 0; pointer-events: none;"
>
    <svg
        id="icono-pause"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-[#c8960c]"
        viewBox="0 0 24 24"
        fill="currentColor"
    >
        <rect x="6" y="4" width="4" height="16" rx="1"></rect>
        <rect x="14" y="4" width="4" height="16" rx="1"></rect>
    </svg>
    <svg
        id="icono-play"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-[#c8960c] hidden"
        viewBox="0 0 24 24"
        fill="currentColor"
    >
        <path d="M8 5v14l11-7z"></path>
    </svg>
</button>
