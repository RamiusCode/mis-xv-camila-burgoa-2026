---
// Portada.astro
---

<section
    id="portada-sobre"
    class="fixed inset-0 z-50 w-full h-full overflow-hidden bg-[#060d1a]"
>
    <!-- FONDO -->
    <img
        src="/imagenes/fondo1.png"
        alt=""
        class="absolute top-0 left-1/2 -translate-x-1/2 h-full w-auto z-0 pointer-events-none"
    />

    <!-- PARTÍCULAS ESTRELLAS -->
    <canvas
        id="canvas-estrellas"
        class="absolute inset-0 w-full h-full z-[1] pointer-events-none"
    ></canvas>

    <!-- OVERLAY TRANSICIÓN DORADA -->
    <div
        id="overlay-dorado"
        class="fixed inset-0 z-[100] pointer-events-none opacity-0"
        style="background: radial-gradient(circle at center, #f5c842 0%, #ffe08a 30%, #fff8dc 60%, #060d1a 100%);"
    >
    </div>

    <!-- CONTENEDOR CENTRAL -->
    <div
        class="relative z-10 w-full h-full max-w-sm mx-auto flex flex-col items-center justify-between px-4 py-4"
    >
        <!-- ── ZONA SUPERIOR: título + nombre ── -->
        <div class="w-full text-center pt-18">
            <!-- "MIS XV AÑOS" → cambia text-xl para más/menos grande -->
            <p
                class="font-crimson font-bold uppercase tracking-widest text-xl text-[#f5c842] mb-2
                      [text-shadow:0_0_14px_rgba(245,200,66,0.55)]"
            >
                MIS XV AÑOS
            </p>

            <!-- NOMBRE → cambia text-6xl para más/menos grande -->
            <h1
                class="font-great-vibes text-[42px] pt-[20px] text-[#f5c842] leading-tight
                       [text-shadow:0_2px_22px_rgba(245,200,66,0.65)]"
            >
                Camila Burgoa
            </h1>
        </div>

        <!-- ── SOBRE + LÁMPARA + TEXTO ── -->
        <!-- Cambia w-80 para ancho del sobre, h-72 para alto -->
        <div
            id="div-sobre"
            class="relative flex-shrink-0 cursor-pointer w-[22rem] h-[22rem]"
        >
            <!-- Imagen del sobre -->
            <img
                src="/imagenes/sobre.png"
                alt="Sobre de invitación"
                class="absolute inset-0 w-full h-full object-contain object-bottom z-[5]"
            />

            <!-- LÁMPARA → cambia w-16 para tamaño, top-10 para posición vertical -->
            <img
                id="lampara"
                src="/imagenes/lampara.png"
                alt="Lámpara mágica"
                class="absolute top-10 left-1/2 -translate-x-1/2 z-10 w-16 pointer-events-none drop-shadow-xl"
            />

            <!-- TEXTO → cambia top-28 para subir/bajar, text-xs para tamaño -->
            <p
                id="texto-click"
                class="absolute top-28 left-1/2 -translate-x-1/2 z-10
                       font-crimson uppercase text-center text-base leading-relaxed
                       text-[#f5e6a8] whitespace-nowrap pointer-events-none m-0
                       [text-shadow:0_2px_10px_rgba(0,0,0,0.95),0_0_20px_rgba(0,0,0,0.7)]"
            >
                PRESIONA EL SOBRE <br />PARAABRIR TU<br />INVITACIÓN
            </p>

            <!-- BOTÓN INVISIBLE -->
            <button
                id="btn-sobre"
                aria-label="Abrir invitación"
                class="absolute inset-0 z-20 bg-transparent border-0 cursor-pointer p-0 outline-none"
            ></button>
        </div>

        <!-- ── ZONA ETIQUETA ── -->
        <!-- Cambia w-full para ancho, scale-[1.1] para agrandar más -->
        <div class="w-full flex items-center justify-center pb-4">
            <div class="relative w-full max-w-sm scale-110">
                <!-- h-36 controla el alto → sube para más espacio interno -->
                <img
                    src="/imagenes/etiqueta.png"
                    alt=""
                    class="w-full h-36 block object-fill"
                />

                <div
                    class="absolute inset-0 flex flex-col items-center justify-center gap-0.5 px-10 py-4"
                >
                    <!-- "PARA" pequeño -->
                    <p
                        class="m-0 font-charm text-[#ffffff] text-xs tracking-widest uppercase opacity-60 leading-none"
                    >
                        — para —
                    </p>

                    <!-- NOMBRE → cambia text-lg para tamaño -->
                    <p
                        class="m-0 font-charm text-[#ffffff] text-lg leading-tight text-center"
                    >
                        Pamela Rodriguez Mendoza
                    </p>

                    <!-- Divisor -->
                    <div class="h-px w-2/3 bg-[#ffffff] opacity-25 my-0.5">
                    </div>

                    <!-- PASE + ICONO PERSONA -->
                    <div class="flex items-center justify-center gap-1.5">
                        <svg
                            class="w-4 h-4 text-[#ffffff] opacity-60 flex-shrink-0"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"
                            ></path>
                        </svg>
                        <!-- Texto pase → cambia text-xs para tamaño -->
                        <p
                            class="m-0 font-charm text-[#ffffff] text-sm tracking-wide leading-none"
                        >
                            Pase válido · 1 persona
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    // ── PARTÍCULAS ESTRELLAS ──
    (function iniciarEstrellas() {
        const canvas = document.getElementById(
            "canvas-estrellas",
        ) as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext("2d")!;

        const resize = () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        };
        resize();
        window.addEventListener("resize", resize);

        // Colores elegantes: blanco puro, dorado suave, dorado pálido
        const colores = [
            "255,255,255",
            "245,200,66",
            "255,232,150",
            "220,210,255",
        ];

        type Estrella = {
            x: number;
            y: number;
            radio: number;
            color: string;
            alfa: number;
            alfaMin: number;
            alfaMax: number;
            alfaVel: number;
            vx: number;
            vy: number;
            pulso: number;
            pulsoVel: number;
            tipo: "punto" | "cruz";
        };

        const CANTIDAD = 90;
        const estrellas: Estrella[] = [];

        const crearEstrella = (forzarYAbajo = false): Estrella => {
            const alfaMax = 0.4 + Math.random() * 0.6;
            return {
                x: Math.random() * canvas.width,
                y: forzarYAbajo
                    ? canvas.height + Math.random() * 40
                    : Math.random() * canvas.height,
                radio: 0.6 + Math.random() * 2.2,
                color: colores[Math.floor(Math.random() * colores.length)],
                alfa: Math.random() * alfaMax,
                alfaMin: 0.02,
                alfaMax,
                alfaVel: 0.004 + Math.random() * 0.012,
                vx: (Math.random() - 0.5) * 0.3,
                vy: -(0.15 + Math.random() * 0.45),
                pulso: Math.random() * Math.PI * 2,
                pulsoVel: 0.02 + Math.random() * 0.04,
                tipo: Math.random() > 0.65 ? "cruz" : "punto",
            };
        };

        for (let i = 0; i < CANTIDAD; i++) estrellas.push(crearEstrella());

        const dibujarCruz = (e: Estrella) => {
            const r = e.radio * 3.5;
            const glow = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, r * 2);
            glow.addColorStop(0, `rgba(${e.color},${e.alfa})`);
            glow.addColorStop(0.4, `rgba(${e.color},${e.alfa * 0.5})`);
            glow.addColorStop(1, `rgba(${e.color},0)`);

            // Halo exterior
            ctx.beginPath();
            ctx.arc(e.x, e.y, r * 2, 0, Math.PI * 2);
            ctx.fillStyle = glow;
            ctx.fill();

            // Brazos de la cruz (destello +)
            ctx.save();
            ctx.globalAlpha = e.alfa;
            ctx.strokeStyle = `rgb(${e.color})`;
            ctx.lineWidth = e.radio * 0.6;
            ctx.lineCap = "round";
            ctx.shadowColor = `rgb(${e.color})`;
            ctx.shadowBlur = 8;

            ctx.beginPath();
            ctx.moveTo(e.x - r, e.y);
            ctx.lineTo(e.x + r, e.y);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(e.x, e.y - r);
            ctx.lineTo(e.x, e.y + r);
            ctx.stroke();

            // Brazos diagonales más cortos
            const rd = r * 0.5;
            ctx.lineWidth = e.radio * 0.3;
            ctx.beginPath();
            ctx.moveTo(e.x - rd, e.y - rd);
            ctx.lineTo(e.x + rd, e.y + rd);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(e.x + rd, e.y - rd);
            ctx.lineTo(e.x - rd, e.y + rd);
            ctx.stroke();
            ctx.restore();
        };

        const dibujarPunto = (e: Estrella) => {
            const glow = ctx.createRadialGradient(
                e.x,
                e.y,
                0,
                e.x,
                e.y,
                e.radio * 4,
            );
            glow.addColorStop(0, `rgba(${e.color},${e.alfa})`);
            glow.addColorStop(0.5, `rgba(${e.color},${e.alfa * 0.3})`);
            glow.addColorStop(1, `rgba(${e.color},0)`);
            ctx.beginPath();
            ctx.arc(e.x, e.y, e.radio * 4, 0, Math.PI * 2);
            ctx.fillStyle = glow;
            ctx.fill();

            ctx.beginPath();
            ctx.arc(e.x, e.y, e.radio, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(${e.color},${Math.min(e.alfa * 1.4, 1)})`;
            ctx.fill();
        };

        let animId: number;
        const animar = () => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (const e of estrellas) {
                e.pulso += e.pulsoVel;
                e.alfa =
                    e.alfaMin +
                    (Math.sin(e.pulso) * 0.5 + 0.5) * (e.alfaMax - e.alfaMin);

                e.x += e.vx;
                e.y += e.vy;

                if (e.tipo === "cruz") dibujarCruz(e);
                else dibujarPunto(e);

                // Reciclar si sale por arriba
                if (e.y < -20) Object.assign(e, crearEstrella(true));
            }
            animId = requestAnimationFrame(animar);
        };
        animar();

        // Detener al salir la portada para no desperdiciar recursos
        document.getElementById("btn-sobre")?.addEventListener(
            "click",
            () => {
                cancelAnimationFrame(animId);
            },
            { once: true },
        );
    })();

    document.addEventListener("DOMContentLoaded", () => {
        const portada = document.getElementById("portada-sobre")!;
        const btnSobre = document.getElementById("btn-sobre")!;

        const tl = gsap.timeline();

        // 1. FONDO: fade in suave
        tl.from(
            "section#portada-sobre > img",
            {
                opacity: 0,
                duration: 2,
                ease: "power2.out",
            },
            0,
        );

        // 2. "MIS XV AÑOS": cae desde arriba + fade
        tl.from(
            "#portada-sobre .text-center > p",
            {
                opacity: 0,
                y: -20,
                duration: 1,
                ease: "power3.out",
            },
            0.3,
        );

        // 3. NOMBRE: efecto escritura letra por letra con resplandor suave
        const h1 = document.querySelector<HTMLElement>(
            "#portada-sobre .text-center > h1",
        );
        if (h1) {
            const texto = h1.textContent ?? "";
            h1.innerHTML = texto
                .split("")
                .map((c) =>
                    c === " "
                        ? `<span style="display:inline-block">&nbsp;</span>`
                        : `<span style="display:inline-block">${c}</span>`,
                )
                .join("");

            // Letras aparecen una a una
            tl.from(
                h1.querySelectorAll("span"),
                {
                    opacity: 0,
                    y: 6,
                    duration: 0.05,
                    stagger: 0.055,
                    ease: "power1.out",
                },
                0.7,
            );

            // Resplandor dorado: entra fuerte al terminar de escribir, luego pulsa suave infinito
            const durEscritura = 0.7 + texto.length * 0.055 + 0.1;
            tl.fromTo(
                h1,
                { filter: "drop-shadow(0 0 0px rgba(245,200,66,0))" },
                {
                    filter: "drop-shadow(0 0 14px rgba(245,200,66,0.9))",
                    duration: 0.7,
                    ease: "power2.out",
                    onComplete: () => {
                        gsap.to(h1, {
                            filter: "drop-shadow(0 0 6px rgba(245,200,66,0.35))",
                            duration: 2.2,
                            ease: "sine.inOut",
                            yoyo: true,
                            repeat: -1,
                        });
                    },
                },
                durEscritura,
            );
        }

        // 4. SOBRE: zoom con rebote desde el centro
        tl.from(
            "#div-sobre",
            {
                scale: 0.1,
                opacity: 0,
                duration: 1,
                ease: "back.out(1.6)",
            },
            0.5,
        );

        // 5. ETIQUETA: aparece con desenfoque gaussiano
        tl.fromTo(
            "#portada-sobre .pb-4",
            { filter: "blur(14px)", opacity: 0, y: 10 },
            {
                filter: "blur(0px)",
                opacity: 1,
                y: 0,
                duration: 1.2,
                ease: "power2.out",
            },
            0.8,
        );

        // 6. Parpadeo "presiona" al terminar la entrada
        tl.to(
            "#texto-click",
            {
                opacity: 0.55,
                duration: 1.4,
                ease: "sine.inOut",
                yoyo: true,
                repeat: -1,
            },
            "+=0.2",
        );

        btnSobre.addEventListener("click", () => {
            // Música
            const audio = new Audio("/musica/melodia.mp3");
            audio.loop = true;
            audio.volume = 0.5;
            audio.play().catch(() => {});
            (window as any).audioGlobal = audio;
            (window as any).estaReproduciendoGlobal = true;

            setTimeout(() => {
                document.getElementById("icono-play")?.classList.add("hidden");
                document
                    .getElementById("icono-pause")
                    ?.classList.remove("hidden");
            }, 100);

            const overlay = document.getElementById("overlay-dorado")!;
            const tlSalida = gsap.timeline();

            // 1. Sobre: zoom suave hacia adelante
            tlSalida.to(
                "#div-sobre",
                {
                    scale: 1.08,
                    duration: 0.9,
                    ease: "power1.inOut",
                },
                0,
            );

            // 2. Destello dorado muy suave desde el centro
            tlSalida.to(
                overlay,
                {
                    opacity: 0.35,
                    duration: 0.7,
                    ease: "power1.in",
                },
                0.2,
            );

            // 3. Toda la portada fade out suave + overlay se vuelve negro
            tlSalida.to(
                portada,
                {
                    opacity: 0,
                    duration: 0.9,
                    ease: "power2.inOut",
                },
                0.6,
            );

            tlSalida.to(
                overlay,
                {
                    opacity: 1,
                    duration: 0.5,
                    ease: "power2.in",
                    onStart: () => {
                        overlay.style.background = "#060d1a";
                    },
                },
                0.9,
            );

            // 4. Mostrar NombresFlores bajo el overlay
            tlSalida.call(() => {
                document.body.style.overflow = "auto";
                portada.remove();
                const nombresFlores =
                    document.getElementById("nombres-flores") ||
                    document.getElementById("contenido-revelado");
                if (nombresFlores) {
                    nombresFlores.style.display = "block";
                    // DISPARAR ANIMACIONES AQUÍ
                    if (typeof (window as any).iniciarAnimacionNombresFlores === "function") {
                        (window as any).iniciarAnimacionNombresFlores();
                    }
                    if (typeof (window as any).iniciarAnimacionDedicatoria === "function") {
                        (window as any).iniciarAnimacionDedicatoria();
                    }
                }

            });

            // 5. Fade out suave del negro revelando NombresFlores
            tlSalida.to(
                overlay,
                {
                    opacity: 0,
                    duration: 1.2,
                    ease: "power2.out",
                    onComplete: () => overlay.remove(),
                },
                "+=0.05",
            );
        });
    });
</script>

<style is:global>
    html,
    body {
        margin: 0;
        padding: 0;
        overflow: hidden;
        width: 100%;
        height: 100%;
    }
</style>
