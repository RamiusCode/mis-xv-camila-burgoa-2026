---
// Hora.astro
---

<div
    id="hora-contenedor"
    class="relative w-full flex items-center justify-center px-4 pt-0 pb-10"
>
    <div
        class="relative w-full max-w-[400px] flex flex-col items-center justify-center"
        style="min-height: 220px;"
    >
        <!-- MONO (arriba derecha) -->
        <img
            id="hora-mono"
            src="/imagenes/mono.png"
            alt="Mono"
            class="absolute top-0 right-[2%] z-[5] pointer-events-none select-none w-[100px] h-auto"
        />

        <!-- PERSONAJE5 (abajo izquierda) -->
        <img
            id="hora-personaje"
            src="/imagenes/personaje5.png"
            alt="Personaje"
            class="absolute bottom-0 left-[-5%] z-[5] pointer-events-none select-none w-[130px] h-auto"
        />

        <!-- RELOJ + TEXTO (centro) -->
        <div class="relative z-[10] flex flex-col items-center gap-[4px]">
            <img
                id="hora-reloj"
                src="/imagenes/reloj.png"
                alt="Reloj"
                class="w-[80px] h-auto pointer-events-none select-none"
            />

            <p
                id="hora-label"
                class="font-charm text-[20px] uppercase tracking-[0.2em] text-[#07c4c7] font-bold m-0"
            >
                Hora
            </p>

            <p
                id="hora-numero"
                class="font-great-vibes text-[72px] text-[#c8960c] leading-[0.9] m-0 [text-shadow:0_2px_18px_rgba(200,150,12,0.4)]"
            >
                7:00
            </p>

            <p
                id="hora-pm"
                class="font-charm text-[20px] uppercase tracking-[0.2em] text-[#07c4c7] font-bold m-0"
            >
                PM
            </p>
        </div>
    </div>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const contenedor = document.getElementById("hora-contenedor");

    if (contenedor) {
        const mono      = document.getElementById("hora-mono");
        const personaje = document.getElementById("hora-personaje");
        const reloj     = document.getElementById("hora-reloj");
        const label     = document.getElementById("hora-label");
        const numero    = document.getElementById("hora-numero");
        const pm        = document.getElementById("hora-pm");

        const reset = () => {
            gsap.set(mono,      { y: -60, opacity: 0 });
            gsap.set(personaje, { x: -70, opacity: 0 });
            gsap.set(reloj,     { scale: 0.7, opacity: 0 });
            gsap.set(label,     { y: 12, opacity: 0 });
            gsap.set(numero,    { scale: 0.75, opacity: 0 });
            gsap.set(pm,        { y: 12, opacity: 0 });
        };
        reset();

        const tl = gsap.timeline({ paused: true });
        tl.to(mono,      { y: 0, opacity: 1, duration: 0.9, ease: "power3.out" }, 0);
        tl.to(personaje, { x: 0, opacity: 1, duration: 0.9, ease: "power3.out" }, 0);
        tl.to(reloj,     { scale: 1, opacity: 1, duration: 0.9, ease: "back.out(1.5)" }, 0);
        tl.to(label,     { y: 0, opacity: 1, duration: 0.9, ease: "power2.out" }, 0);
        tl.to(numero,    { scale: 1, opacity: 1, duration: 0.9, ease: "back.out(1.4)" }, 0);
        tl.to(pm,        { y: 0, opacity: 1, duration: 0.9, ease: "power2.out" }, 0);

        ScrollTrigger.create({
            trigger: contenedor,
            start: "top 98%",
            onEnter: () => tl.restart(),
            onLeaveBack: () => { tl.pause(0); reset(); },
        });
    }
</script>
