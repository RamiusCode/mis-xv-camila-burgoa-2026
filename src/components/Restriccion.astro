<div
    id="rest-contenedor"
    class="relative flex flex-col justify-center items-center p-8 bg-cover bg-center"
>
    <div id="rest-marco-wrap" class="relative">
        <img
            id="rest-marco"
            src="/imagenes/marco7.png"
            alt="Marco"
            class="h-auto w-[400px]"
        />

        <div
            id="rest-texto"
            class="absolute inset-0 flex items-center justify-center px-10 text-center"
        >
            <p
                class="font-crimson text-[#0a6c6e] text-base leading-relaxed font-bold"
            >
                CON CARIÑO, ESTE <br /> EVENTO ES SOLO PARA<br />ADULTOS.<br />
                AGRADECEMOS SU COMPRENSIÓN.
            </p>
        </div>
    </div>

    <img
        id="rest-lampara"
        src="/imagenes/lampara2.png"
        alt="Lámpara"
        class="absolute bottom-2 left-2 w-24 md:w-32"
    />
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const initRestriccion = () => {
        const contenedor = document.getElementById("rest-contenedor");
        if (!contenedor) return;

        const lampara = document.getElementById("rest-lampara");
        const marco = document.getElementById("rest-marco");
        const texto = document.getElementById("rest-texto");

        const reset = () => {
            gsap.set(lampara, { x: -60, opacity: 0 });
            gsap.set(marco, { scale: 0.92, opacity: 0 });
            gsap.set(texto, { y: 16, opacity: 0 });
        };
        reset();

        const tl = gsap.timeline({ paused: true });

        // 1. Lámpara entra desde la izquierda
        tl.to(
            lampara,
            { x: 0, opacity: 1, duration: 0.9, ease: "power3.out" },
            0,
        );

        // 2. Marco escala
        tl.to(
            marco,
            { scale: 1, opacity: 1, duration: 0.9, ease: "power2.out" },
            0.25,
        );

        // 3. Texto sube suave
        tl.to(
            texto,
            { y: 0, opacity: 1, duration: 0.8, ease: "power2.out" },
            0.7,
        );

        ScrollTrigger.create({
            trigger: contenedor,
            start: "top 85%",
            onEnter: () => tl.restart(),
            onLeaveBack: () => {
                tl.pause(0);
                reset();
            },
        });
    };

    document.addEventListener("DOMContentLoaded", initRestriccion);
</script>
