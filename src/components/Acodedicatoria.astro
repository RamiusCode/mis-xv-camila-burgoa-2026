---
// Invitacion.astro
---

<div
    id="acoded-contenedor"
    class="relative w-full overflow-hidden flex items-center justify-center px-[24px] py-[40px]"
>
    <div
        class="relative z-10 flex flex-col items-center justify-center text-center gap-6 max-w-[400px]"
    >
        <!-- LÁMPARA -->
        <img
            id="acoded-lampara"
            src="/imagenes/lampara.png"
            alt="Lámpara mágica"
            class="w-[100px] h-auto pointer-events-none select-none"
        />

        <!-- TEXTO SUPERIOR -->
        <p
            id="acoded-texto-sup"
            class="font-crimson text-lg uppercase text-[#07c4c7] leading-relaxed m-0"
        >
            TENEMOS EL AGRADO DE INVITARTE A CELEBRAR LOS 15 AÑOS DE NUESTRA
            QUERIDA HIJA
        </p>

        <!-- NOMBRE -->
        <h1
            id="acoded-nombre"
            class="font-great-vibes text-[52px] text-[#c8960c] leading-[1.1] m-0"
        >
            Camila Burgoa
        </h1>

        <!-- TEXTO INFERIOR -->
        <p
            id="acoded-texto-inf"
            class="font-crimson text-lg uppercase text-[#07c4c7] leading-relaxed m-0"
        >
            ACOMPÁÑANOS EN ESTE DÍA TAN ESPECIAL, LLENO DE AMOR Y ALEGRÍA
        </p>
    </div>
</div>
