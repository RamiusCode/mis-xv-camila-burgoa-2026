---
// Invitacion.astro
---

<div
    id="acoded-contenedor"
    class="relative w-full overflow-hidden flex items-center justify-center px-[24px] py-[40px]"
>
    <div
        class="relative z-10 flex flex-col items-center justify-center text-center gap-6 max-w-[400px]"
    >
        <!-- LÁMPARA -->
        <img
            id="acoded-lampara"
            src="/imagenes/lampara.png"
            alt="Lámpara mágica"
            class="w-[100px] h-auto pointer-events-none select-none"
        />

        <!-- TEXTO SUPERIOR -->
        <p
            id="acoded-texto-sup"
            class="font-crimson text-lg uppercase text-[#07c4c7] leading-relaxed m-0"
        >
            TENEMOS EL AGRADO DE INVITARTE A CELEBRAR LOS 15 AÑOS DE NUESTRA
            QUERIDA HIJA
        </p>

        <!-- NOMBRE -->
        <h1
            id="acoded-nombre"
            class="font-great-vibes text-[52px] text-[#c8960c] leading-[1.1] m-0"
        >
            Camila Burgoa
        </h1>

        <!-- TEXTO INFERIOR -->
        <p
            id="acoded-texto-inf"
            class="font-crimson text-lg uppercase text-[#07c4c7] leading-relaxed m-0"
        >
            ACOMPÁÑANOS EN ESTE DÍA TAN ESPECIAL, LLENO DE AMOR Y ALEGRÍA
        </p>
    </div>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const contenedor = document.getElementById("acoded-contenedor");

    if (contenedor) {
        const lampara  = document.getElementById("acoded-lampara");
        const textoSup = document.getElementById("acoded-texto-sup");
        const nombre   = document.getElementById("acoded-nombre") as HTMLElement;
        const textoInf = document.getElementById("acoded-texto-inf");

        if (nombre) {
            const texto = nombre.textContent ?? "";
            nombre.innerHTML = texto
                .split("")
                .map((c) =>
                    c === " "
                        ? `<span style="display:inline-block">&nbsp;</span>`
                        : `<span style="display:inline-block">${c}</span>`,
                )
                .join("");
        }

        const reset = () => {
            gsap.set(lampara,  { y: -40, opacity: 0 });
            gsap.set(textoSup, { y: 20, opacity: 0 });
            if (nombre) gsap.set(nombre.querySelectorAll("span"), { y: 6, opacity: 0 });
            gsap.set(textoInf, { y: 20, opacity: 0 });
        };
        reset();

        const tl = gsap.timeline({ paused: true });
        tl.to(lampara,  { y: 0, opacity: 1, duration: 0.9, ease: "power3.out" }, 0);
        tl.to(textoSup, { y: 0, opacity: 1, duration: 0.9, ease: "power2.out" }, 0);
        if (nombre) {
            tl.to(nombre.querySelectorAll("span"), {
                y: 0, opacity: 1,
                duration: 0.8,
                stagger: 0.04,
                ease: "sine.out",
            }, 0);
        }
        tl.to(textoInf, { y: 0, opacity: 1, duration: 0.9, ease: "power2.out" }, 0);

        window.addEventListener("load", () => {
            ScrollTrigger.create({
                trigger: contenedor,
                start: "top 98%",
                onEnter: () => tl.restart(),
                onLeaveBack: () => {
                    tl.pause(0);
                reset();
            },
        });
        });
    }
</script>
