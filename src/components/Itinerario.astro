<style>
    .dorado-filter {
        filter: brightness(0) saturate(100%) invert(35%) sepia(80%)
            saturate(300%) hue-rotate(150deg) brightness(85%) contrast(90%);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initItinerario() {
        const seccion = document.getElementById("iti-seccion");
        if (!seccion) return;

        const card = document.getElementById("iti-card");
        const titulo = document.getElementById("iti-titulo");
        const items = seccion.querySelectorAll(".iti-animate");

        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: seccion,
                start: "top 80%",
                toggleActions: "play none none reset",
            }
        });

        // Animación inicial de la tarjeta y título
        tl.from(card, {
            opacity: 0,
            y: 40,
            duration: 1,
            ease: "power2.out",
        })
        .from(titulo, {
            opacity: 0,
            y: -20,
            duration: 0.8,
            ease: "power2.out",
        }, "-=0.6");

        // Animación suave y delicada de todos los hitos al mismo tiempo
        items.forEach((item) => {
            if (item.classList.contains('flex')) {
                // Es una estrella
                tl.from(item, {
                    scale: 0.8,
                    opacity: 0,
                    duration: 1.5,
                    ease: "power2.out"
                }, 0.5);
            } else if (item.classList.contains('grid')) {
                // Es una fila de evento (2 columnas)
                const leftCol = item.children[0];
                const rightCol = item.children[1];

                tl.from(leftCol, {
                    x: -20,
                    opacity: 0,
                    duration: 1.5,
                    ease: "power3.out"
                }, 0.5)
                .from(rightCol, {
                    x: 20,
                    opacity: 0,
                    duration: 1.5,
                    ease: "power3.out"
                }, 0.5);
            }
        });


    }

    document.addEventListener("DOMContentLoaded", initItinerario);
    document.addEventListener("astro:page-load", initItinerario);
</script>



<style>
    .dorado-filter {
        filter: brightness(0) saturate(100%) invert(35%) sepia(80%)
            saturate(300%) hue-rotate(150deg) brightness(85%) contrast(90%);
    }
</style>
