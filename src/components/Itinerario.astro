---
// Itinerario.astro
---

<section class="px-4 relative overflow-hidden py-6">
    <div class="max-w-5xl mx-auto relative z-10">
        <div class="max-w-3xl mx-auto relative">
            <!-- CARD SEMITRANSPARENTE -->
            <div
                class="rounded-2xl border border-[#c8960c]/30 px-6 py-8 md:px-10 md:py-10"
                style="background: rgba(255,255,255,0.15); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
            >
                <!-- Título -->
                <div class="text-center mb-6 titulo-itinerario opacity-0">
                    <h2
                        class="font-great-vibes text-[38px] text-[#c8960c] font-normal mb-3"
                    >
                        Itinerario
                    </h2>
                    <div class="flex items-center justify-center gap-3">
                        <div
                            class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#c8960c]"
                        >
                        </div>
                        <div class="w-2 h-2 rounded-full bg-[#c8960c]"></div>
                        <div
                            class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#c8960c]"
                        >
                        </div>
                    </div>
                </div>

                <div class="relative px-4 md:px-8">
                    <!-- Línea central -->
                    <div
                        class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] bg-gradient-to-b from-[#f5e6a8] via-[#c8960c] to-[#f5e6a8] rounded-full linea-central opacity-0"
                    >
                    </div>

                    <div class="space-y-0" id="eventos-container">
                        <!-- Estrella 1 -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                        <!-- Evento 1: Recepción -->
                        <div
                            class="evento-item grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0"
                        >
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 imagen-izq"
                            >
                                <div
                                    class="w-14 h-14 md:w-16 md:h-16 flex items-center justify-center"
                                >
                                    <img
                                        src="/iconos/recepcion.png"
                                        alt="Recepción"
                                        class="w-full h-full object-contain icono-color dorado-filter"
                                    />
                                </div>
                            </div>
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-der"
                            >
                                <p
                                    class="font-charm text-lg md:text-2xl text-[#07c4c7] font-bold leading-tight"
                                >
                                    Recepción
                                </p>
                                <p
                                    class="font-charm text-base md:text-xl text-[#c8960c] mt-0.5"
                                >
                                    07:00 p. m.
                                </p>
                            </div>
                        </div>

                        <!-- Estrella 2 -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                        <!-- Evento 2: Vals -->
                        <div
                            class="evento-item grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0"
                        >
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-izq"
                            >
                                <p
                                    class="font-charm text-lg md:text-2xl text-[#07c4c7] font-bold leading-tight"
                                >
                                    Vals
                                </p>
                                <p
                                    class="font-charm text-base md:text-xl text-[#c8960c] mt-0.5"
                                >
                                    09:00 p. m.
                                </p>
                            </div>
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 imagen-der"
                            >
                                <div
                                    class="w-14 h-14 md:w-16 md:h-16 flex items-center justify-center"
                                >
                                    <img
                                        src="/iconos/vals.png"
                                        alt="Vals"
                                        class="w-full h-full object-contain dorado-filter"
                                    />
                                </div>
                            </div>
                        </div>

                        <!-- Estrella 3 -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                        <!-- Evento 3: Brindis y fotos -->
                        <div
                            class="evento-item grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0"
                        >
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 imagen-izq"
                            >
                                <div
                                    class="w-14 h-14 md:w-16 md:h-16 flex items-center justify-center"
                                >
                                    <img
                                        src="/iconos/brindis.png"
                                        alt="Brindis"
                                        class="w-full h-full object-contain dorado-filter"
                                    />
                                </div>
                            </div>
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-der"
                            >
                                <p
                                    class="font-charm text-lg md:text-2xl text-[#07c4c7] font-bold leading-tight"
                                >
                                    Brindis y Fotos
                                </p>
                                <p
                                    class="font-charm text-base md:text-xl text-[#c8960c] mt-0.5"
                                >
                                    10:00 p. m.
                                </p>
                            </div>
                        </div>

                        <!-- Estrella 4 -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                        <!-- Evento 4: Cena -->
                        <div
                            class="evento-item grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0"
                        >
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-izq"
                            >
                                <p
                                    class="font-charm text-lg md:text-2xl text-[#07c4c7] font-bold leading-tight"
                                >
                                    Cena
                                </p>
                                <p
                                    class="font-charm text-base md:text-xl text-[#c8960c] mt-0.5"
                                >
                                    10:30 p. m.
                                </p>
                            </div>
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 imagen-der"
                            >
                                <div
                                    class="w-14 h-14 md:w-16 md:h-16 flex items-center justify-center"
                                >
                                    <img
                                        src="/iconos/cena.png"
                                        alt="Cena"
                                        class="w-full h-full object-contain dorado-filter"
                                    />
                                </div>
                            </div>
                        </div>

                        <!-- Estrella 5 -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                        <!-- Evento 5: Hora loca -->
                        <div
                            class="evento-item grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0"
                        >
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 imagen-izq"
                            >
                                <div
                                    class="w-14 h-14 md:w-16 md:h-16 flex items-center justify-center"
                                >
                                    <img
                                        src="/iconos/musica.png"
                                        alt="Hora loca"
                                        class="w-full h-full object-contain dorado-filter"
                                    />
                                </div>
                            </div>
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-der"
                            >
                                <p
                                    class="font-charm text-lg md:text-2xl text-[#07c4c7] font-bold leading-tight"
                                >
                                    Hora Loca
                                </p>
                                <p
                                    class="font-charm text-base md:text-xl text-[#c8960c] mt-0.5"
                                >
                                    11:30 p. m.
                                </p>
                            </div>
                        </div>

                        <!-- Estrella 6 -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                        <!-- Evento 6: Torta -->
                        <div
                            class="evento-item grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0"
                        >
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-izq"
                            >
                                <p
                                    class="font-charm text-lg md:text-2xl text-[#07c4c7] font-bold leading-tight"
                                >
                                    Torta
                                </p>
                                <p
                                    class="font-charm text-base md:text-xl text-[#c8960c] mt-0.5"
                                >
                                    01:00 a. m.
                                </p>
                            </div>
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 imagen-der"
                            >
                                <div
                                    class="w-14 h-14 md:w-16 md:h-16 flex items-center justify-center"
                                >
                                    <img
                                        src="/iconos/pastel.png"
                                        alt="Torta"
                                        class="w-full h-full object-contain dorado-filter"
                                    />
                                </div>
                            </div>
                        </div>

                        <!-- Estrella 7 -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                        <!-- Evento 7: Fin de la fiesta -->
                        <div
                            class="evento-item grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0"
                        >
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 imagen-izq"
                            >
                                <div
                                    class="w-14 h-14 md:w-16 md:h-16 flex items-center justify-center"
                                >
                                    <img
                                        src="/iconos/fin-fiesta.png"
                                        alt="Fin"
                                        class="w-full h-full object-contain dorado-filter"
                                    />
                                </div>
                            </div>
                            <div
                                class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-der"
                            >
                                <p
                                    class="font-charm text-lg md:text-2xl text-[#07c4c7] font-bold leading-tight"
                                >
                                    Fin de la Fiesta
                                </p>
                                <p
                                    class="font-charm text-base md:text-xl text-[#c8960c] mt-0.5"
                                >
                                    03:00 a. m.
                                </p>
                            </div>
                        </div>

                        <!-- Estrella Final -->
                        <div class="flex justify-center py-1">
                            <div
                                class="w-8 h-8 rounded-full bg-[#c8960c] flex items-center justify-center relative z-10 corazon-item shadow-md opacity-0"
                            >
                                <span class="text-white text-[14px]">✦</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .dorado-filter {
        filter: brightness(0) saturate(100%) invert(35%) sepia(80%)
            saturate(300%) hue-rotate(150deg) brightness(85%) contrast(90%);
    }
    .corazon-item {
        filter: drop-shadow(0 4px 12px rgba(200, 150, 12, 0.5));
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .corazon-item:hover {
        transform: scale(1.2) rotate(10deg);
    }
    .evento-item p {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .evento-item:hover p:first-of-type {
        transform: scale(1.05);
    }
    .linea-central {
        box-shadow:
            0 0 8px rgba(200, 150, 12, 0.6),
            0 0 20px rgba(200, 150, 12, 0.2);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const initItinerario = () => {
        gsap.set(".titulo-itinerario", { opacity: 0, y: -30 });
        gsap.set(".linea-central", { opacity: 0, scaleY: 0 });
        gsap.set(".corazon-item", { opacity: 0, scale: 0 });
        gsap.set(".evento-item", { opacity: 0 });
        gsap.set(".imagen-izq", { x: -60 });
        gsap.set(".texto-izq", { x: -60 });
        gsap.set(".imagen-der", { x: 60 });
        gsap.set(".texto-der", { x: 60 });

        ScrollTrigger.create({
            trigger: ".titulo-itinerario",
            start: "top 98%",
            once: true,
            onEnter: () => {
                gsap.to(".titulo-itinerario", {
                    opacity: 1,
                    y: 0,
                    duration: 1.2,
                    ease: "power3.out",
                });
            },
        });

        ScrollTrigger.create({
            trigger: "#eventos-container",
            start: "top 98%",
            end: "top 20%",
            onEnter: () => {
                const tl = gsap.timeline();
                tl.to(
                    ".linea-central",
                    {
                        opacity: 1,
                        scaleY: 1,
                        duration: 1.5,
                        ease: "power2.out",
                        transformOrigin: "top center",
                    },
                    0,
                )
                    .to(
                        ".corazon-item",
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.8,
                            ease: "back.out(1.7)",
                        },
                        0,
                    )
                    .to(
                        ".evento-item",
                        { opacity: 1, duration: 1, ease: "power3.out" },
                        0,
                    )
                    .to(
                        ".imagen-izq, .texto-izq",
                        { x: 0, duration: 1, ease: "power3.out" },
                        0,
                    )
                    .to(
                        ".imagen-der, .texto-der",
                        { x: 0, duration: 1, ease: "power3.out" },
                        0,
                    );
            },
            onLeaveBack: () => {
                const tl = gsap.timeline();
                tl.to(
                    ".linea-central, .corazon-item, .evento-item",
                    { opacity: 0, duration: 0.4, ease: "power2.in" },
                    0,
                )
                    .to(
                        ".linea-central",
                        {
                            scaleY: 0,
                            duration: 0.4,
                            ease: "power2.in",
                            transformOrigin: "top center",
                        },
                        0,
                    )
                    .to(
                        ".corazon-item",
                        { scale: 0, duration: 0.4, ease: "power2.in" },
                        0,
                    )
                    .to(
                        ".imagen-izq, .texto-izq",
                        { x: -60, duration: 0.4, ease: "power2.in" },
                        0,
                    )
                    .to(
                        ".imagen-der, .texto-der",
                        { x: 60, duration: 0.4, ease: "power2.in" },
                        0,
                    );
            },
        });
    };

    document.addEventListener("DOMContentLoaded", initItinerario);
    document.addEventListener("astro:page-load", initItinerario);
</script>
